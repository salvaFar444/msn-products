# Copy this file to .env.local and fill in the values.
# No secrets belong in source control — keep .env.local out of git.

# -----------------------------------------------------------------------------
# Auth.js (NextAuth v5)
# Generate a secret with: openssl rand -base64 32
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Admin credentials (used for the initial seed; change after first login)
# -----------------------------------------------------------------------------
ADMIN_EMAIL=
ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# WhatsApp business number (Colombian format: 573XXXXXXXXX — no + or spaces)
# Used as a fallback; primary source is data/site.ts
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WHATSAPP_NUMBER=573215009685

# -----------------------------------------------------------------------------
# Public base URL (used for canonical links, OG tags, sitemap)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000
